{
    "interface_version": 2,
    "name": "MaaWuwa",
    "description": "启动鸣潮，并在登录界面自动点击连接/登录按钮。MXU/WlRoots 下需要先启动嵌套 labwc，再切换连接到新出现的 wayland socket。",
    "contact": "",
    "license": "MIT",
    "welcome": "欢迎使用 MaaWuwa。",
    "version": "1.0.0",
    "agent": {
        "child_exec": "agent/MaaWuwa.Agent",
        "child_args": [
            "--native-dir",
            "libs/MaaAgentBinary"
        ]
    },
    "controller": [
        {
            "name": "labwc",
            "label": "Linux 桌面端（labwc/WlRoots）",
            "type": "WlRoots",
            "display_short_side": 720,
            "wlroots": {
                "use_win32_vk_code": true
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ],
            "controller": [
                "labwc"
            ]
        }
    ],
    "task": [
        {
            "name": "启动鸣潮（先运行）",
            "entry": "LaunchWuwaLabwc",
            "default_check": false,
            "description": "先连接当前桌面的 wayland socket 运行本任务，启动 /home/shulk/sh/labwc-wuwa.sh。等新 socket（如 wayland-0）出现后，在连接设置中切换到它。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "点击连接并领取索拉指南",
            "entry": "LoginAndOpenMenu",
            "default_check": true,
            "description": "连接到嵌套 labwc 的 socket（如 wayland-0）后运行：自动判断当前在登录页、加载中、游戏内或菜单页；需要时点击连接，进入游戏后按 Esc 打开菜单，点击索拉指南并领取奖励。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "固定坐标点击连接（调试）",
            "entry": "ClickWuwaConnectFixed",
            "default_check": false,
            "description": "不做图片识别，直接通过嵌套 Xwayland 的 XTest 点击 1280x720 画面底部中央登录按钮。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "打开菜单（调试）",
            "entry": "OpenWuwaMenuOnly",
            "default_check": false,
            "description": "游戏内直接通过嵌套 Xwayland 的 XTest 发送 Escape，并验证菜单锚点是否出现。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "领取索拉指南（调试）",
            "entry": "ClaimSolaGuideDebug",
            "default_check": false,
            "description": "菜单页或索拉指南页均可运行：若已看到“领取”则直接点击，否则先点击索拉指南，再识别“领取”按钮并点击。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "自动战斗（第一版/调试）",
            "entry": "AutoCombat",
            "default_check": false,
            "description": "连接到嵌套 labwc 的游戏画面并确认在游戏内后运行：C# Agent 持续截图识别敌人/技能状态，执行通用自动战斗策略。首版仅支持前台可见窗口和固定三人队配置。",
            "controller": [
                "labwc"
            ]
        }
    ]
}
