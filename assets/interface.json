{
    "interface_version": 2,
    "name": "MaaWuwa",
    "description": "启动鸣潮，并在登录界面自动点击连接/登录按钮。MXU/WlRoots 下需要先启动嵌套 labwc，再切换连接到新出现的 wayland socket。",
    "contact": "",
    "license": "MIT",
    "welcome": "欢迎使用 MaaWuwa。",
    "version": "1.0.0",
    "controller": [
        {
            "name": "labwc",
            "label": "Linux 桌面端（labwc/WlRoots）",
            "type": "WlRoots",
            "display_short_side": 720,
            "wlroots": {
                "use_win32_vk_code": true
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ],
            "controller": [
                "labwc"
            ]
        }
    ],
    "task": [
        {
            "name": "启动鸣潮（先运行）",
            "entry": "LaunchWuwaLabwc",
            "default_check": false,
            "description": "先连接当前桌面的 wayland socket 运行本任务，启动 /home/shulk/sh/labwc-wuwa.sh。等新 socket（如 wayland-0）出现后，在连接设置中切换到它。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "点击连接",
            "entry": "ClickWuwaConnect",
            "default_check": true,
            "description": "连接到嵌套 labwc 的 socket（如 wayland-0）后运行，用 WlRoots 截图在底部区域识别“点击连接”，再通过嵌套 Xwayland 的 XTest 点击底部中央。固定坐标点击有效时推荐使用此任务。",
            "controller": [
                "labwc"
            ]
        },
        {
            "name": "固定坐标点击连接（调试）",
            "entry": "ClickWuwaConnectFixed",
            "default_check": false,
            "description": "不做图片识别，直接通过嵌套 Xwayland 的 XTest 点击 1280x720 画面底部中央登录按钮。",
            "controller": [
                "labwc"
            ]
        }
    ]
}
